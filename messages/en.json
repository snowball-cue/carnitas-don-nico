      "title": "Common questions",
      "subtitle": "If you don't see your question here, just drop it in the notes box above.",
      "howFar": {
        "q": "How far ahead should I book?",
        "a": "A week is ideal — big events need a few days to source meat and prep. We can sometimes fit in rush orders, but earlier is always better."
      },
      "travel": {
        "q": "Do you travel? What's your delivery area?",
        "a": "Yes, within our local area. Toggle delivery on in the form and tell us where — we'll quote the trip."
      },
      "bulk": {
        "q": "Discounts for bulk orders?",
        "a": "For very large events (50+ lbs) we can usually work out a bulk rate. Mention it in the notes and Don Nico will take it into account."
      },
      "whatsIncluded": {
        "q": "What's included by default?",
        "a": "Just the carnitas, sold by the pound. Tortillas, salsas, and sides are a simple add-on — flip the 'Include sides?' switch."
      },
      "deposit": {
        "q": "Do you require a deposit?",
        "a": "For confirmed catering bookings, yes — we'll let you know the amount when we quote. It locks in your date."
      },
      "cancellations": {
        "q": "What if I need to cancel?",
        "a": "Let us know as soon as you can. Cancellations more than 72 hours out are usually no problem."
      }
    },
